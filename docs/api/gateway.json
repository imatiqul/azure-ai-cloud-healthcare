{
  "openapi": "3.0.3",
  "info": {
    "title": "HealthQ Copilot — API Gateway",
    "description": "YARP reverse-proxy API Gateway. All paths are transparently forwarded to the appropriate downstream microservice. No business logic resides at the gateway layer. APIM sits in front of the gateway and enforces JWT validation, rate limiting, and subscription key checks.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "/", "description": "API Gateway (YARP)" }
  ],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/v1/agents/{catch-all}": {
      "get": {
        "operationId": "proxyAgentsGet",
        "summary": "Proxy GET requests to the AI Agent Service",
        "tags": ["Agents Proxy"],
        "parameters": [{ "name": "catch-all", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Proxied response from AI Agent Service" } }
      },
      "post": {
        "operationId": "proxyAgentsPost",
        "summary": "Proxy POST requests to the AI Agent Service",
        "tags": ["Agents Proxy"],
        "parameters": [{ "name": "catch-all", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Proxied response from AI Agent Service" } }
      },
      "put": {
        "operationId": "proxyAgentsPut",
        "summary": "Proxy PUT requests to the AI Agent Service",
        "tags": ["Agents Proxy"],
        "parameters": [{ "name": "catch-all", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Proxied response from AI Agent Service" } }
      },
      "delete": {
        "operationId": "proxyAgentsDelete",
        "summary": "Proxy DELETE requests to the AI Agent Service",
        "tags": ["Agents Proxy"],
        "parameters": [{ "name": "catch-all", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Proxied response from AI Agent Service" } }
      }
    },
