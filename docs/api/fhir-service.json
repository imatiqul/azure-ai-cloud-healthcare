      }
    },
    "/imaging/{studyId}": {
      "get": {
        "operationId": "getDicomImaging",
        "summary": "WADO-RS proxy for DICOM imaging studies (OHIF viewer integration)",
        "tags": ["Imaging"],
        "parameters": [{ "name": "studyId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "DICOM study metadata" } }
      }
    },
    "/events": {
      "post": {
        "operationId": "ingestHl7Event",
        "summary": "Ingest HL7v2 MLLP events (ADT/ORU/ORM) via HTTP bridge",
        "tags": ["Events"],
        "responses": { "200": { "description": "Event ingested" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  }
}
