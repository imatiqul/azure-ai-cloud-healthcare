      }
    },
    "/coverage": {
      "get": {
        "operationId": "searchCoverage",
        "summary": "Search FHIR Coverage resources",
        "tags": ["Coverage"],
        "responses": { "200": { "description": "Coverage bundle" } }
      },
      "post": {
        "operationId": "createCoverage",
        "summary": "Create a FHIR Coverage resource",
        "tags": ["Coverage"],
        "responses": { "201": { "description": "Coverage created" } }
      }
    },
    "/coverage/{id}": {
      "get": {
        "operationId": "getCoverage",
        "summary": "Get a FHIR Coverage resource by ID",
        "tags": ["Coverage"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Coverage resource" } }
      },
      "put": {
        "operationId": "updateCoverage",
        "summary": "Update a FHIR Coverage resource",
        "tags": ["Coverage"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Coverage updated" } }
      }
    },
    "/coverage/{id}/$eligibility": {
      "post": {
        "operationId": "checkEligibility",
        "summary": "Check insurance eligibility for a coverage resource",
        "tags": ["Coverage"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Eligibility response" } }
      }
    },
    "/explanation-of-benefit": {
      "get": {
        "operationId": "searchExplanationOfBenefit",
        "summary": "Search FHIR ExplanationOfBenefit resources",
        "tags": ["Explanation of Benefit"],
        "responses": { "200": { "description": "EOB bundle" } }
      },
      "post": {
        "operationId": "createExplanationOfBenefit",
        "summary": "Create a FHIR ExplanationOfBenefit resource",
        "tags": ["Explanation of Benefit"],
        "responses": { "201": { "description": "EOB created" } }
      }
    },
    "/explanation-of-benefit/{id}": {
      "get": {
        "operationId": "getExplanationOfBenefit",
        "summary": "Get a FHIR ExplanationOfBenefit by ID",
        "tags": ["Explanation of Benefit"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
