      }
    },
    "/diagnostic-reports/{patientId}": {
      "get": {
        "operationId": "getDiagnosticReports",
        "summary": "Get FHIR DiagnosticReport resources for a patient",
        "tags": ["Diagnostics"],
        "parameters": [{ "name": "patientId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "DiagnosticReports bundle" } }
      }
    },
    "/care-teams/{patientId}": {
      "get": {
        "operationId": "getCareTeams",
        "summary": "Get FHIR CareTeam resources for a patient",
        "tags": ["Care Teams"],
        "parameters": [{ "name": "patientId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "CareTeams bundle" } }
      }
    },
    "/appointments/{patientId}": {
      "get": {
        "operationId": "getAppointmentsByPatient",
        "summary": "Get FHIR Appointment resources for a patient",
        "tags": ["Appointments"],
        "parameters": [{ "name": "patientId", "in": "path", "required": true, "schema": { "type": "string" } }],
