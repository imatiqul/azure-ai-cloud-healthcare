{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "agents-route": {
        "ClusterId": "agent-service",
        "Match": {
          "Path": "/api/v1/agents/{**catch-all}"
        }
      },
      "voice-route": {
        "ClusterId": "voice-service",
        "Match": {
          "Path": "/api/v1/voice/{**catch-all}"
        }
      },
      "voice-webpubsub-route": {
        "ClusterId": "voice-service",
        "Match": {
          "Path": "/api/webpubsub/{**catch-all}"
        }
      },
      "scheduling-route": {
        "ClusterId": "scheduling-service",
        "Match": {
          "Path": "/api/v1/scheduling/{**catch-all}"
        }
      },
      "pophealth-route": {
        "ClusterId": "pophealth-service",
        "Match": {
          "Path": "/api/v1/population-health/{**catch-all}"
        }
      },
      "revenue-route": {
        "ClusterId": "revenue-service",
        "Match": {
          "Path": "/api/v1/revenue/{**catch-all}"
        }
      },
      "fhir-route": {
        "ClusterId": "fhir-service",
        "Match": {
          "Path": "/api/v1/fhir/{**catch-all}"
        }
      },
      "fhir-metadata-route": {
        "ClusterId": "fhir-service",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/fhir/metadata"
        },
        "Transforms": [
          { "PathSet": "/api/v1/fhir/metadata" }
        ]
      },
      "fhir-smart-route": {
        "ClusterId": "fhir-service",
        "AuthorizationPolicy": "Anonymous",
        "Match": {
          "Path": "/.well-known/{**catch-all}"
        }
      },
      "identity-route": {
        "ClusterId": "identity-service",
        "Match": {
          "Path": "/api/v1/identity/{**catch-all}"
        }
      },
      "identity-admin-audit-route": {
        "ClusterId": "identity-service",
        "Match": {
          "Path": "/api/v1/admin/audit/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notification-service",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        }
      },
      "ocr-route": {
        "ClusterId": "ocr-service",
        "Match": {
          "Path": "/api/v1/ocr/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "agent-service": {
        "Destinations": {
          "default": {
            "Address": "https+http://agent-service"
          }
        }
      },
      "voice-service": {
        "Destinations": {
          "default": {
            "Address": "https+http://voice-service"
          }
        }
      },
      "scheduling-service": {
        "Destinations": {
          "default": {
            "Address": "https+http://scheduling-service"
          }
        }
      },
      "pophealth-service": {
        "Destinations": {
          "default": {
            "Address": "https+http://pophealth-service"
          }
        }
      },
      "revenue-service": {
        "Destinations": {
          "default": {
            "Address": "https+http://revenue-service"
          }
        }
      },
      "fhir-service": {
        "Destinations": {
          "default": {
            "Address": "https+http://fhir-service"
          }
        }
      },
      "identity-service": {
        "Destinations": {
          "default": {
            "Address": "https+http://identity-service"
          }
        }
      },
      "notification-service": {
        "Destinations": {
          "default": {
            "Address": "https+http://notification-service"
          }
        }
      },
      "ocr-service": {
        "Destinations": {
          "default": {
            "Address": "https+http://ocr-service"
          }
        }
      }
    }
  }
}
